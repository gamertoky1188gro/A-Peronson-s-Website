{
  "name": "meow",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "server": "node --watch server/server.js",
    "dev:full": "concurrently \"npm run server\" \"npm run dev -- --host 0.0.0.0\"",
    "app": "npm run build && concurrently -k -s first \"npm run server\" \"wait-on tcp:4000 dist/index.html && electron electron/main.cjs\"",
    "docs:generate": "node scripts/generate-docs-index.mjs && node scripts/render-docs.mjs",
    "db:generate": "prisma generate",
    "db:migrate:dev": "prisma migrate dev",
    "db:studio": "prisma studio",
    "db:migrate:pg": "prisma migrate dev",
    "db:backfill:org-operations": "node scripts/db/backfill-org-operations-policies.mjs",
    "ai:eval": "node scripts/run-ai-extraction-regression.mjs",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js --runInBand",
    "test:unit": "node --experimental-vm-modules node_modules/jest/bin/jest.js --runInBand --testPathPattern=tests/unit",
    "test:e2e": "playwright test",
    "ci:reindex": "node scripts/ci/reindex-opensearch.mjs",
    "ci:smoke": "node scripts/ci/smoke-search.mjs",
    "ci:full": "npm run ci:reindex && npm test && npm run ci:smoke",
    "worker:lead-reminders": "node server/workers/leadRemindersWorker.js"
  },
