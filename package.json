    "googleapis": "^133.0.0",
    "jsonwebtoken": "^9.0.3",
    "leaflet": "^1.9.4",
    "lucide-react": "^0.575.0",
    "multer": "^2.1.0",
    "nodemailer": "^6.10.1",
    "pdfjs-dist": "^5.5.207",
    "prismjs": "^1.30.0",
