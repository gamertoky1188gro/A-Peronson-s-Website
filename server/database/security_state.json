{
  "zero_trust": {
    "enabled": true,
    "policy": "deny-by-default"
  },
  "mfa": {
    "required": true,
    "methods": [
      "totp",
      "sms"
    ]
  },
  "session": {
    "timeout_minutes": 30,
    "device_fingerprinting": true
  },
  "ip_whitelist": [],
  "geo_fence": {
    "enabled": false,
    "countries": []
  },
  "tamper_proof_logs": {
    "enabled": true,
    "storage": "local",
    "last_hash_at": ""
  },
  "encryption": {
    "key_rotation_days": 90,
    "last_rotated_at": ""
  },
  "incidents": [],
  "data_exports": {
    "dual_approval": true,
    "pending": []
  },
  "forensic_logs": [],
  "immutable_backups": {
    "enabled": true,
    "last_snapshot_at": ""
  }
}