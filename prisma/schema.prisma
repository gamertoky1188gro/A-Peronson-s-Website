// Prisma schema for GarTexHub (PostgreSQL)
// Source of truth: PostgreSQL (no JSON files).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                         String   @id
  name                       String
  email                      String   @unique
  password_hash              String
  role                       String
  status                     String
  verified                   Boolean  @default(false)
  subscription_status        String   @default("free")
  wallet_balance_usd         Float    @default(0)
  wallet_restricted_usd      Float    @default(0)
  policy_strikes             Int      @default(0)
  messaging_restricted_until DateTime?
  profile                    Json?
  org_owner_id               String?
  member_id                  String?
  username                   String?
  permissions                Json?
  permission_matrix          Json?
  assigned_requests          Int?
  performance_score          Int?
  chatbot_enabled            Boolean  @default(false)
  handoff_mode               String?
  created_at                 DateTime @default(now())
  updated_at                 DateTime?
  password_reset_at          DateTime?

  ownedLeads                Lead[]           @relation("LeadOrgOwner")
  assignedLeads             Lead[]           @relation("LeadAssignedAgent")
  counterpartyLeads         Lead[]           @relation("LeadCounterpartyUser")
  leadNotes                 LeadNote[]       @relation("LeadNoteAuthor")
  leadRemindersCreated      LeadReminder[]   @relation("LeadReminderCreator")
  crmInteractionsOwned      InteractionLog[] @relation("InteractionOrgOwner")
  crmInteractionsActor      InteractionLog[] @relation("InteractionActor")
  leadAssignmentsByActor    LeadAssignment[] @relation("LeadAssignmentActor")
  leadAssignmentsTargeted   LeadAssignment[] @relation("LeadAssignmentTarget")
  agentCapacityRecords      AgentCapacity[]  @relation("AgentCapacityAgent")

  @@map("users")
}

model Subscription {
  id         String   @id
  user_id    String
  plan       String
  start_date DateTime
  end_date   DateTime
  auto_renew Boolean  @default(true)

  @@map("subscriptions")
}

model Verification {
  user_id                    String   @id
  role                       String
  buyer_region               String?
  documents                  Json
  verified                   Boolean  @default(false)
  verified_at                DateTime?
  subscription_valid_until   DateTime?
  missing_required           Json?
  credibility                Json?
  subscription_remaining_days Int?
  expiring_soon               Boolean?
  verification_status         String?
  review_status               String?
  review_reason               String?
  reviewed_at                 DateTime?
  updated_at                 DateTime?

  @@map("verification")
}

model Requirement {
  id                     String   @id
  buyer_id               String
  title                  String
  description            String? @db.Text
  request_type           String   @default("garments")
  verified_only          Boolean  @default(false)
  specs                  Json?
  custom_fields          Json?
  quote_deadline         DateTime?
  expires_at             DateTime?
  max_suppliers          Int?
  product                String?
  industry               String?
  category               String?
  target_market          String?
  quantity               String?
  moq                    String?
  price_range            String?
  currency               String?
  priceOriginalMin       Float?
  priceOriginalMax       Float?
  priceBaseMin           Float?
  priceBaseMax           Float?
  priceNormalizedBase    Float?
  material               String?
  fabric_gsm             String?
  timeline_days          String?
  delivery_timeline      String?
  certifications_required Json?
  shipping_terms         String?
  incoterms              String?
  payment_terms          String?
  document_ready         String?
  audit_date             String?
  language_support       String?
  capacity_min           String?
  trims_wash             String?
  sample_timeline        String?
  sample_available       String?
  packaging              String?
  compliance_notes       String?
  custom_description     String?
  size_range             String?
  color_pantone          String?
  customization_capabilities String?
  techpack_accepted      Boolean?
  sample_lead_time_days  String?
  compliance_details     String?
  ai_summary             String?
  assigned_agent_id      String?
  assigned_at            DateTime?
  assigned_by            String?
  status                 String
  moderated              Boolean?
  moderation_reason      String?
  created_at             DateTime @default(now())
  updated_at             DateTime?

  @@map("requirements")
}

model Product {
  id                     String   @id
  company_id             String
  company_role           String
  title                  String
  industry               String?
  category               String?
  material               String?
  moq                    String?
  price_range            String?
  currency               String?
  priceOriginalMin       Float?
  priceOriginalMax       Float?
  priceBaseMin           Float?
  priceBaseMax           Float?
  priceNormalizedBase    Float?
  lead_time_days         String?
  fabric_gsm             String?
  size_range             String?
  color_pantone          String?
  customization_capabilities String?
  sample_available       String?
  sample_lead_time_days  String?
  description            String?
  image_urls             Json?
  cover_image_url        String?
  status                 String?
  video_url              String?
  video_review_status    String?
  video_restricted       Boolean?
  video_moderation_flags Json?
  video_reviewed_at      DateTime?
  video_review_reason    String?
  moderated              Boolean?
  moderation_reason      String?
  created_at             DateTime @default(now())
  updated_at             DateTime?

  @@map("company_products")
}

model FxRate {
  id        String   @id @default(cuid())
  base      String
  quote     String
  rate      Float
  source    String
  fetchedAt DateTime @default(now())
  expiresAt DateTime

  @@unique([base, quote], name: "fx_base_quote")
  @@index([expiresAt])
  @@map("fx_rates")
}

model CurrencyConfig {
  id                     String   @id @default("default")
  baseCurrency           String   @default("USD")
  staleToleranceMinutes  Int      @default(1440)
  updatedAt              DateTime @updatedAt

  @@map("currency_config")
}

model Message {
  id                String           @id
  match_id          String
  sender_id         String
  message           String?          @db.Text
  timestamp         DateTime         @default(now())
  type              String?
  attachment        Json?
  moderated         Boolean?
  moderation_reason String?
  interactions      InteractionLog[]

  @@map("messages")
}

model MessageRequest {
  thread_id String @id
  status    String
  acted_by  String?
  acted_at  DateTime?

  @@map("message_requests")
}

model Notification {
  id         String   @id
  user_id    String
  type       String
  entity_type String?
  entity_id  String?
  message    String
  meta       Json?
  read       Boolean  @default(false)
  created_at DateTime @default(now())

  @@map("notifications")
}

model SearchAlert {
  id         String   @id
  user_id    String
  query      String
  filters    Json?
  created_at DateTime @default(now())
  updated_at DateTime?

  @@map("search_alerts")
}

model SearchUsageCounter {
  user_id    String
  action     String
  date       String
  count      Int
  updated_at DateTime?
  reset_at   DateTime?

  @@id([user_id, action], name: "user_id_action")
  @@map("search_usage_counters")
}

model ConversationLock {
  request_id     String @id
  locked_by      String
  allowed_agents Json?
  allowed_users  Json?
  lock_type      String?
  lock_status    String?
  lock_reason    String?
  created_at     DateTime @default(now())
  updated_at     DateTime?

  @@map("conversation_locks")
}

model PaymentProof {
  id                  String   @id
  contract_id         String
  type                String
  status              String
  created_by          String
  reviewed_by         String?
  review_reason       String?
  transaction_reference String?
  bank_name           String?
  sender_account_name String?
  receiver_account_name String?
  transaction_date    DateTime?
  amount              Float?
  currency            String?
  lc_number           String?
  issuing_bank        String?
  advising_bank       String?
  applicant_name      String?
  beneficiary_name    String?
  issue_date          DateTime?
  expiry_date         DateTime?
  lc_type             String?
  usance_days         Int?
  document_id         String?
  document_url        String?
  created_at          DateTime @default(now())
  updated_at          DateTime?

  @@map("payment_proofs")
}

model PartnerRequest {
  id             String   @id
  requester_id   String
  requester_role String
  target_id      String
  target_role    String
  status         String
  created_at     DateTime @default(now())
  updated_at     DateTime?

  @@map("partner_requests")
}

model CallSession {
  id                String           @id
  created_by        String
  match_id          String?
  title             String?
  scheduled_for     DateTime?
  duration_minutes  Int?
  participant_ids   Json?
  status            String?
  recording_url     String?
  recording_status  String?
  contract_id       String?
  security_audit_id String?
  context           Json?
  created_at        DateTime         @default(now())
  started_at        DateTime?
  ended_at          DateTime?
  audit_trail       Json?
  interactions      InteractionLog[]

  @@map("call_sessions")
}

model CallRecordingView {
  id        String   @id
  call_id   String
  viewer_id String
  viewed_at DateTime @default(now())

  @@map("call_recording_views")
}

model Document {
  id                    String   @id
  uploaded_by           String
  entity_type           String
  entity_id             String
  file_path             String?
  type                  String?
  created_at            DateTime @default(now())
  updated_at            DateTime?

  contract_number       String?
  title                 String?
  buyer_name            String?
  factory_name          String?
  buyer_id              String?
  factory_id            String?
  bank_name             String?
  beneficiary_name      String?
  transaction_reference String?
  is_draft              Boolean?
  buyer_signature_state String?
  factory_signature_state String?
  buyer_signed_at        DateTime?
  factory_signed_at      DateTime?
  artifact               Json?
  lifecycle_status       String?
  archived_at            DateTime?

  moderation_flags       Json?
  moderation_status      String?

  @@map("documents")
}

model Lead {
  id                  String           @id
  org_owner_id        String
  match_id            String
  counterparty_id     String?
  source              String?
  source_type         String?
  source_id           String?
  source_label        String?
  status              String?
  assigned_agent_id   String?
  conversion_at       DateTime?
  created_at          DateTime         @default(now())
  updated_at          DateTime?
  last_interaction_at DateTime?
  orgOwner            User             @relation("LeadOrgOwner", fields: [org_owner_id], references: [id], onDelete: Restrict, onUpdate: Cascade)
  assignedAgent       User?            @relation("LeadAssignedAgent", fields: [assigned_agent_id], references: [id], onDelete: SetNull, onUpdate: Cascade)
  counterpartyUser    User?            @relation("LeadCounterpartyUser", fields: [counterparty_id], references: [id], onDelete: SetNull, onUpdate: Cascade)
  notes               LeadNote[]
  reminders           LeadReminder[]
  interactions        InteractionLog[]
  assignments         LeadAssignment[]

  @@index([org_owner_id, status, updated_at])
  @@index([assigned_agent_id, updated_at])
  @@map("leads")
}

model LeadAssignment {
  id                String   @id
  lead_id           String
  org_owner_id      String
  assigned_by       String?
  assigned_to       String?
  previous_assignee String?
  reason            String?
  assigned_at       DateTime @default(now())
  created_at        DateTime @default(now())
  lead              Lead     @relation(fields: [lead_id], references: [id], onDelete: Cascade, onUpdate: Cascade)
  actor             User?    @relation("LeadAssignmentActor", fields: [assigned_by], references: [id], onDelete: SetNull, onUpdate: Cascade)
  targetAgent       User?    @relation("LeadAssignmentTarget", fields: [assigned_to], references: [id], onDelete: SetNull, onUpdate: Cascade)

  @@index([org_owner_id, assigned_at])
  @@map("lead_assignments")
}

model AgentCapacity {
  id                   String   @id
  org_owner_id         String
  agent_id             String
  max_concurrent_leads Int
  current_load         Int      @default(0)
  updated_at           DateTime @default(now())
  agent                User     @relation("AgentCapacityAgent", fields: [agent_id], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@unique([org_owner_id, agent_id], name: "agent_capacity_org_owner_id_agent_id")
  @@map("agent_capacity")
}

model LeadNote {
  id           String   @id
  lead_id      String
  org_owner_id String
  author_id    String
  note         String?
  created_at   DateTime @default(now())
  lead         Lead     @relation(fields: [lead_id], references: [id], onDelete: Cascade, onUpdate: Cascade)
  author       User     @relation("LeadNoteAuthor", fields: [author_id], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@index([lead_id, created_at])
  @@map("lead_notes")
}

model LeadReminder {
  id           String   @id
  lead_id      String
  org_owner_id String
  created_by   String
  remind_at    DateTime
  message      String?
  done         Boolean  @default(false)
  notified_at  DateTime?
  created_at   DateTime @default(now())
  lead         Lead     @relation(fields: [lead_id], references: [id], onDelete: Cascade, onUpdate: Cascade)
  creator      User     @relation("LeadReminderCreator", fields: [created_by], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@index([lead_id, remind_at, done])
  @@map("lead_reminders")
}

model InteractionLog {
  id               String      @id
  org_owner_id     String
  actor_id         String?
  channel          String?
  interaction_type String
  entity_type      String?
  entity_id        String?
  lead_id          String?
  message_id       String?
  call_session_id  String?
  event_log_id     String?
  match_id         String?
  metadata         Json?
  occurred_at      DateTime
  created_at       DateTime    @default(now())
  orgOwner         User        @relation("InteractionOrgOwner", fields: [org_owner_id], references: [id], onDelete: Restrict, onUpdate: Cascade)
  actor            User?       @relation("InteractionActor", fields: [actor_id], references: [id], onDelete: SetNull, onUpdate: Cascade)
  lead             Lead?       @relation(fields: [lead_id], references: [id], onDelete: SetNull, onUpdate: Cascade)
  message          Message?    @relation(fields: [message_id], references: [id], onDelete: SetNull, onUpdate: Cascade)
  callSession      CallSession? @relation(fields: [call_session_id], references: [id], onDelete: SetNull, onUpdate: Cascade)
  eventLog         EventLog?   @relation(fields: [event_log_id], references: [id], onDelete: SetNull, onUpdate: Cascade)

  @@index([org_owner_id, interaction_type, occurred_at])
  @@map("interaction_logs")
}

model EventLog {
  id           String           @id
  org_owner_id String
  actor_id     String?
  event_type   String
  entity_type  String?
  entity_id    String?
  payload      Json?
  occurred_at  DateTime
  created_at   DateTime         @default(now())
  interactions InteractionLog[]

  @@index([org_owner_id, event_type, occurred_at])
  @@map("event_logs")
}

model AnalyticsEvent {
  id         String   @id
  type       String
  actor_id   String?
  entity_id  String?
  metadata   Json?
  created_at DateTime @default(now())

  @@map("analytics")
}

model Boost {
  id         String   @id
  user_id    String
  scope      String
  multiplier Float
  status     String
  starts_at  DateTime
  ends_at    DateTime
  price_usd  Float
  created_at DateTime @default(now())
  cancelled_at DateTime?

  @@map("boosts")
}

model ProductView {
  id         String   @id
  user_id    String
  product_id String
  viewed_at  DateTime @default(now())
  created_at DateTime @default(now())
  updated_at DateTime?

  @@map("product_views")
}

model Report {
  id                String   @id
  status            String
  entity_type       String
  entity_id         String
  reason            String?
  actor_id          String?
  actor_name        String?
  meta              Json?
  created_at        DateTime @default(now())
  resolved_at       DateTime?
  resolved_by       String?
  resolution_action String?
  resolution_note   String?

  @@map("reports")
}

model PolicyViolation {
  id                       String   @id
  actor_id                 String
  kind                     String?
  reason                   String?
  entity_type              String?
  entity_id                String?
  snippet                  String?
  strikes                  Int?
  action                   String?
  restrict_hours           Int?
  messaging_restricted_until DateTime?
  meta                     Json?
  created_at               DateTime @default(now())

  @@map("violations")
}

model SocialInteraction {
  id               String   @id
  interaction_type String
  entity_type      String
  entity_id        String
  actor_id         String
  actor_name       String?
  actor_verified   Boolean?
  text             String?
  created_at       DateTime @default(now())

  @@map("social_interactions")
}

model UserConnection {
  id           String   @id
  type         String
  requester_id String
  receiver_id  String
  status       String
  created_at   DateTime @default(now())
  updated_at   DateTime?

  @@map("user_connections")
}

model Match {
  requirement_id String
  factory_id     String
  score          Int?
  status         String?
  created_at     DateTime @default(now())

  @@id([requirement_id, factory_id], name: "requirement_id_factory_id")
  @@map("matches")
}

model MetricTransition {
  id             String   @id
  requirement_id String?
  from_status    String?
  to_status      String?
  context        Json?
  created_at     DateTime @default(now())

  @@map("metrics")
}

model AssistantKnowledge {
  id         String   @id
  org_id     String?
  type       String?
  question   String   @db.Text
  answer     String   @db.Text
  keywords   Json?
  tags       Json?
  source     String?
  created_at DateTime @default(now())
  updated_at DateTime?

  @@map("assistant_knowledge")
}

model Rating {
  id                String   @id
  profile_key       String
  from_user_id      String
  interaction_type  String?
  score             Int?
  comment           String?
  reliability_flags Json?
  auto_generated    Boolean  @default(false)
  created_at        DateTime @default(now())

  @@map("ratings")
}

model RatingMilestone {
  id               String   @id
  profile_key      String
  counterparty_id  String
  interaction_type String?
  milestone        String
  status           String?
  completed_at     DateTime?
  created_at       DateTime @default(now())
  updated_at       DateTime?
  updated_by       String?

  @@map("rating_milestones")
}

model RatingFeedbackRequest {
  id                 String   @id
  profile_key        String
  counterparty_id    String
  interaction_type   String?
  qualification_rules Json?
  status             String?
  triggered_by       String?
  created_at         DateTime @default(now())
  fulfilled_at       DateTime?

  @@map("rating_feedback_requests")
}

model RatingFeedbackEvent {
  id               String   @id
  profile_key      String
  counterparty_id  String
  interaction_type String?
  event            String?
  milestone        String?
  created_at       DateTime @default(now())

  @@map("rating_feedback_events")
}

model WalletHistory {
  id               String   @id
  user_id          String
  kind             String?
  amount_usd       Float?
  balance_after_usd Float?
  reason           String?
  ref              String?
  meta             Json?
  created_at       DateTime @default(now())

  @@map("wallet_history")
}

model CouponCode {
  id              String   @id
  code            String   @unique
  amount_usd      Float
  active          Boolean  @default(true)
  max_redemptions Int?
  expires_at      DateTime?
  created_by      String?
  marketing_source String?
  created_at      DateTime @default(now())

  @@map("coupon_codes")
}

model CouponRedemption {
  id          String   @id
  code_id     String
  user_id     String
  amount_usd  Float
  redeemed_at DateTime @default(now())

  @@unique([code_id, user_id])
  @@map("coupon_redemptions")
}

model MessageRead {
  id           String   @id
  match_id     String
  user_id      String
  last_read_at DateTime
  updated_at   DateTime?

  @@unique([match_id, user_id], name: "match_id_user_id")
  @@map("message_reads")
}

model AppState {
  key        String   @id
  data       Json
  updated_at DateTime @default(now())

  @@map("app_state")
}

model OrgSeat {
  id            String   @id
  org_id        String
  member_id     String
  status        String   @default("active")
  role_id       String?
  team          String?
  sub_team      String?
  created_at    DateTime @default(now())
  updated_at    DateTime?

  @@unique([org_id, member_id], name: "org_id_member_id")
  @@map("org_seats")
}

model OrgRole {
  id          String   @id
  org_id      String
  code        String
  name        String
  description String?
  created_at  DateTime @default(now())
  updated_at  DateTime?

  @@unique([org_id, code], name: "org_id_role_code")
  @@map("org_roles")
}

model OrgPermission {
  id          String   @id
  role_id     String
  module      String
  action      String
  allow       Boolean  @default(true)
  created_at  DateTime @default(now())

  @@unique([role_id, module, action], name: "role_module_action")
  @@map("org_permissions")
}

model OrgPolicy {
  id          String   @id
  org_id      String
  code        String
  description String?
  config      Json?
  assignment_strategy String?
  sla_targets         Json?
  escalation_windows  Json?
  active      Boolean  @default(true)
  created_at  DateTime @default(now())
  updated_at  DateTime?

  @@unique([org_id, code], name: "org_id_policy_code")
  @@map("org_policies")
}

model OrgMembershipAudit {
  id               String   @id
  org_id           String
  actor_id         String
  member_id        String?
  action           String
  decision         String
  policy_id        String?
  reason           String?
  resource_context Json?
  created_at       DateTime @default(now())

  @@index([org_id, created_at])
  @@map("org_membership_audit")
}
