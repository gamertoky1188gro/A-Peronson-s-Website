generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                                                String           @id
  name                                              String
  email                                             String           @unique
  password_hash                                     String
  role                                              String
  status                                            String
  verified                                          Boolean          @default(false)
  subscription_status                               String           @default("free")
  wallet_balance_usd                                Float            @default(0)
  wallet_restricted_usd                             Float            @default(0)
  policy_strikes                                    Int              @default(0)
  messaging_restricted_until                        DateTime?
  profile                                           Json?
  org_owner_id                                      String?
  member_id                                         String?
  username                                          String?
  permissions                                       Json?
  permission_matrix                                 Json?
  assigned_requests                                 Int?
  performance_score                                 Int?
  chatbot_enabled                                   Boolean          @default(false)
  handoff_mode                                      String?
  created_at                                        DateTime         @default(now())
  updated_at                                        DateTime?
  password_reset_at                                 DateTime?
  agentCapacityRecords                              AgentCapacity[]  @relation("AgentCapacityAgent")
  event_logs_event_logs_actor_idTousers             EventLog[]       @relation("event_logs_actor_idTousers")
  event_logs_event_logs_org_owner_idTousers         EventLog[]       @relation("event_logs_org_owner_idTousers")
  crmInteractionsActor                              InteractionLog[] @relation("InteractionActor")
  crmInteractionsOwned                              InteractionLog[] @relation("InteractionOrgOwner")
  leadAssignmentsByActor                            LeadAssignment[] @relation("LeadAssignmentActor")
  leadAssignmentsTargeted                           LeadAssignment[] @relation("LeadAssignmentTarget")
  leadNotes                                         LeadNote[]       @relation("LeadNoteAuthor")
  lead_notes_lead_notes_org_owner_idTousers         LeadNote[]       @relation("lead_notes_org_owner_idTousers")
  leadRemindersCreated                              LeadReminder[]   @relation("LeadReminderCreator")
  lead_reminders_lead_reminders_org_owner_idTousers LeadReminder[]   @relation("lead_reminders_org_owner_idTousers")
  assignedLeads                                     Lead[]           @relation("LeadAssignedAgent")
  counterpartyLeads                                 Lead[]           @relation("LeadCounterpartyUser")
  ownedLeads                                        Lead[]           @relation("LeadOrgOwner")

  @@map("users")
}

model Subscription {
  id         String   @id
  user_id    String
  plan       String
  start_date DateTime
  end_date   DateTime
  auto_renew Boolean  @default(true)

  @@map("subscriptions")
}

model Verification {
  user_id                     String    @id
  role                        String
  buyer_region                String?
  documents                   Json
  verified                    Boolean   @default(false)
  verified_at                 DateTime?
  subscription_valid_until    DateTime?
  missing_required            Json?
  credibility                 Json?
  subscription_remaining_days Int?
  expiring_soon               Boolean?
  verification_status         String?
  review_status               String?
  review_reason               String?
  reviewed_at                 DateTime?
  updated_at                  DateTime?

  @@map("verification")
}

model Requirement {
  id                         String    @id
  buyer_id                   String
  title                      String
  description                String?
  request_type               String    @default("garments")
  verified_only              Boolean   @default(false)
  specs                      Json?
  custom_fields              Json?
  quote_deadline             DateTime?
  expires_at                 DateTime?
  max_suppliers              Int?
  product                    String?
  industry                   String?
  category                   String?
  target_market              String?
  quantity                   String?
  moq                        String?
  price_range                String?
  material                   String?
  fabric_gsm                 String?
  timeline_days              String?
  delivery_timeline          String?
  certifications_required    Json?
  shipping_terms             String?
  incoterms                  String?
  payment_terms              String?
  document_ready             String?
  audit_date                 String?
  language_support           String?
  capacity_min               String?
  trims_wash                 String?
  sample_timeline            String?
  sample_available           String?
  packaging                  String?
  compliance_notes           String?
  custom_description         String?
  size_range                 String?
  color_pantone              String?
  customization_capabilities String?
  techpack_accepted          Boolean?
  sample_lead_time_days      String?
  compliance_details         String?
  ai_summary                 String?
  assigned_agent_id          String?
  assigned_at                DateTime?
  assigned_by                String?
  status                     String
  moderated                  Boolean?
  moderation_reason          String?
  created_at                 DateTime  @default(now())
  updated_at                 DateTime?
  priceOriginal              Float?
  currencyOriginal           String?
  priceNormalizedBase        Float?

  @@map("requirements")
}

model Product {
  id                         String    @id
  company_id                 String
  company_role               String
  title                      String
  industry                   String?
  category                   String?
  material                   String?
  moq                        String?
  price_range                String?
  lead_time_days             String?
  fabric_gsm                 String?
  size_range                 String?
  color_pantone              String?
  customization_capabilities String?
  sample_available           String?
  sample_lead_time_days      String?
  description                String?
  image_urls                 Json?
  cover_image_url            String?
  status                     String?
  video_url                  String?
  video_review_status        String?
  video_restricted           Boolean?
  video_moderation_flags     Json?
  video_reviewed_at          DateTime?
  video_review_reason        String?
  moderated                  Boolean?
  moderation_reason          String?
  created_at                 DateTime  @default(now())
  updated_at                 DateTime?
  priceOriginal              Float?
  currencyOriginal           String?
  priceNormalizedBase        Float?

  @@map("company_products")
}

model FeedPost {
  id                   String   @id
  user_id              String
  title                String
  description_markdown String
  caption              String?
  cta_text             String?
  cta_url              String?
  hashtags             Json?
  emojis               Json?
  mentions             Json?
  links                Json?
  product_tags         Json?
  location_tag         String?
  media                Json?
  category             String?
  status               String   @default("published")
  created_at           DateTime @default(now())
  updated_at           DateTime?

  @@index([user_id, created_at])
  @@map("feed_posts")
}

model FxRate {
  id        String   @id @default(cuid())
  base      String
  quote     String
  rate      Float
  source    String
  fetchedAt DateTime @default(now())
  expiresAt DateTime

  @@unique([base, quote], name: "fx_base_quote", map: "fx_base_quote")
  @@index([expiresAt])
  @@map("fx_rates")
}

model CurrencyConfig {
  id                  String   @id @default("default")
  defaultBaseCurrency String   @default("USD")
  staleThresholdHours Int      @default(24)
  updatedAt           DateTime @default(now()) @updatedAt

  @@map("currency_config")
}

model Message {
  id                    String           @id
  match_id              String
  sender_id             String
  message               String?
  timestamp             DateTime         @default(now())
  type                  String?
  attachment            Json?
  moderated             Boolean?
  moderation_reason     String?
  policy_status         String?
  policy_reason         String?
  policy_priority       String?
  retry_after_seconds   Int?
  requires_human_review Boolean?
  queue_id              String?
  interactions          InteractionLog[]

  @@map("messages")
}

model MessageRequest {
  thread_id String    @id
  status    String
  acted_by  String?
  acted_at  DateTime?

  @@map("message_requests")
}

model MessageQueue {
  id                    String    @id
  message_id            String?
  match_id              String
  sender_id             String
  org_id                String?
  queue_status          String
  queue_rank            String
  queue_score           Int
  queue_priority_label  String?
  policy_reason         String?
  retry_after_seconds   Int?
  requires_human_review Boolean   @default(false)
  metadata              Json?
  created_at            DateTime  @default(now())
  updated_at            DateTime?

  @@map("message_queue")
}

model MessagePolicyDecision {
  id                      String    @id
  queue_id                String?
  sender_id               String
  org_id                  String?
  match_id                String
  action                  String
  reason                  String
  trust_score             Int
  keyword_risk_score      Float
  frequency_count         Int
  first_response_priority Boolean   @default(false)
  queue_rank              String?
  queue_score             Int?
  queue_priority_label    String?
  retry_after_seconds     Int?
  requires_human_review   Boolean   @default(false)
  false_positive          Boolean   @default(false)
  reviewer_id             String?
  reviewer_notes          String?
  created_at              DateTime  @default(now())
  updated_at              DateTime?

  @@map("message_policy_decisions")
}

model SenderReputation {
  id                    String    @id
  sender_id             String    @unique
  trust_score           Float     @default(50)
  spam_reports          Int       @default(0)
  positive_interactions Int       @default(0)
  updated_at            DateTime?

  @@map("sender_reputation")
}

model CommunicationPolicyConfig {
  id                          String    @id
  scope                       String
  org_id                      String?
  max_outreach_per_window     Int
  outreach_window_minutes     Int
  cooldown_seconds            Int
  premium_boost               Int
  verified_boost              Int
  keyword_risk_threshold_soft Float
  keyword_risk_threshold_hard Float
  updated_by                  String?
  updated_at                  DateTime?

  @@map("communication_policy_configs")
}

model MessageQueueItem {
  id                    String    @id
  message_id            String?
  match_id              String
  sender_id             String
  org_id                String?
  queue_status          String
  queue_rank            String
  queue_score           Int
  queue_priority_label  String?
  policy_reason         String?
  retry_after_seconds   Int?
  requires_human_review Boolean   @default(false)
  metadata              Json?
  created_at            DateTime  @default(now())
  updated_at            DateTime?

  @@map("message_queue_items")
}

model MessagePolicyLog {
  id                              String    @id
  queue_id                        String?
  sender_id                       String
  org_id                          String?
  match_id                        String
  action                          String
  reason                          String
  reputation_score                Float
  spam_score                      Float
  frequency_count                 Int
  first_response_priority         Boolean   @default(false)
  queue_rank                      String?
  queue_score                     Int?
  queue_priority_label            String?
  premium_verified_priority_score Float?
  retry_after_seconds             Int?
  moderation_flag                 Boolean   @default(false)
  false_positive                  Boolean   @default(false)
  reviewer_id                     String?
  reviewer_notes                  String?
  created_at                      DateTime  @default(now())
  updated_at                      DateTime?

  @@map("message_policy_logs")
}

model CommunicationLimit {
  id                   String    @id
  scope                String
  org_id               String?
  message_caps         Json
  priority_multipliers Json
  strictness_mode      String
  spam_thresholds      Json?
  updated_by           String?
  updated_at           DateTime?

  @@map("communication_limits")
}

model Notification {
  id          String   @id
  user_id     String
  type        String
  entity_type String?
  entity_id   String?
  message     String
  meta        Json?
  read        Boolean  @default(false)
  created_at  DateTime @default(now())

  @@map("notifications")
}

model SearchAlert {
  id         String    @id
  user_id    String
  query      String
  filters    Json?
  created_at DateTime  @default(now())
  updated_at DateTime?

  @@map("search_alerts")
}

model SearchUsageCounter {
  user_id    String
  action     String
  date       String
  count      Int
  updated_at DateTime?
  reset_at   DateTime?

  @@id([user_id, action], name: "user_id_action")
  @@map("search_usage_counters")
}

model ConversationLock {
  request_id     String    @id
  locked_by      String
  allowed_agents Json?
  allowed_users  Json?
  lock_type      String?
  lock_status    String?
  lock_reason    String?
  created_at     DateTime  @default(now())
  updated_at     DateTime?

  @@map("conversation_locks")
}

model PaymentProof {
  id                    String    @id
  contract_id           String
  type                  String
  status                String
  created_by            String
  reviewed_by           String?
  review_reason         String?
  transaction_reference String?
  bank_name             String?
  sender_account_name   String?
  receiver_account_name String?
  transaction_date      DateTime?
  amount                Float?
  currency              String?
  lc_number             String?
  issuing_bank          String?
  advising_bank         String?
  applicant_name        String?
  beneficiary_name      String?
  issue_date            DateTime?
  expiry_date           DateTime?
  document_id           String?
  document_url          String?
  created_at            DateTime  @default(now())
  updated_at            DateTime?
  lc_type               String?
  usance_days           Int?

  @@map("payment_proofs")
}

model PartnerRequest {
  id             String    @id
  requester_id   String
  requester_role String
  target_id      String
  target_role    String
  status         String
  created_at     DateTime  @default(now())
  updated_at     DateTime?

  @@map("partner_requests")
}

model CallSession {
  id                String           @id
  created_by        String
  match_id          String?
  title             String?
  scheduled_for     DateTime?
  duration_minutes  Int?
  participant_ids   Json?
  status            String?
  recording_url     String?
  recording_status  String?
  contract_id       String?
  security_audit_id String?
  context           Json?
  created_at        DateTime         @default(now())
  started_at        DateTime?
  ended_at          DateTime?
  audit_trail       Json?
  interactions      InteractionLog[]

  @@map("call_sessions")
}

model CallRecordingView {
  id        String   @id
  call_id   String
  viewer_id String
  viewed_at DateTime @default(now())

  @@map("call_recording_views")
}

model Document {
  id                      String    @id
  uploaded_by             String
  entity_type             String
  entity_id               String
  file_path               String?
  type                    String?
  created_at              DateTime  @default(now())
  updated_at              DateTime?
  contract_number         String?
  title                   String?
  buyer_name              String?
  factory_name            String?
  buyer_id                String?
  factory_id              String?
  bank_name               String?
  beneficiary_name        String?
  transaction_reference   String?
  is_draft                Boolean?
  buyer_signature_state   String?
  factory_signature_state String?
  buyer_signed_at         DateTime?
  factory_signed_at       DateTime?
  artifact                Json?
  lifecycle_status        String?
  archived_at             DateTime?
  moderation_flags        Json?
  moderation_status       String?

  @@map("documents")
}

model Lead {
  id                  String           @id
  org_owner_id        String
  match_id            String
  counterparty_id     String?
  source              String?
  status              String?
  assigned_agent_id   String?
  created_at          DateTime         @default(now())
  updated_at          DateTime?
  last_interaction_at DateTime?
  source_type         String?
  source_id           String?
  source_label        String?
  conversion_at       DateTime?
  interactions        InteractionLog[]
  assignments         LeadAssignment[]
  escalations         LeadEscalation[]
  notes               LeadNote[]
  reminders           LeadReminder[]
  slaTimers           LeadSlaTimer[]
  assignedAgent       User?            @relation("LeadAssignedAgent", fields: [assigned_agent_id], references: [id])
  counterpartyUser    User?            @relation("LeadCounterpartyUser", fields: [counterparty_id], references: [id])
  orgOwner            User             @relation("LeadOrgOwner", fields: [org_owner_id], references: [id])

  @@index([org_owner_id, status, updated_at])
  @@index([assigned_agent_id, updated_at])
  @@index([org_owner_id, assigned_agent_id, counterparty_id, match_id, status, updated_at], map: "leads_org_owner_id_assigned_agent_id_counterparty_id_match_id_s")
  @@map("leads")
}

model LeadAssignment {
  id                String   @id
  lead_id           String
  org_owner_id      String
  assigned_by       String?
  assigned_to       String?
  previous_assignee String?
  reason            String?
  assigned_at       DateTime @default(now())
  created_at        DateTime @default(now())
  actor             User?    @relation("LeadAssignmentActor", fields: [assigned_by], references: [id])
  targetAgent       User?    @relation("LeadAssignmentTarget", fields: [assigned_to], references: [id])
  lead              Lead     @relation(fields: [lead_id], references: [id], onDelete: Cascade)

  @@index([org_owner_id, assigned_at])
  @@map("lead_assignments")
}

model AgentCapacity {
  id                   String   @id
  org_owner_id         String
  agent_id             String
  max_concurrent_leads Int
  current_load         Int      @default(0)
  updated_at           DateTime @default(now())
  agent                User     @relation("AgentCapacityAgent", fields: [agent_id], references: [id], onDelete: Cascade)

  @@unique([org_owner_id, agent_id], name: "agent_capacity_org_owner_id_agent_id", map: "agent_capacity_org_owner_id_agent_id")
  @@map("agent_capacity")
}

model OrgOpsPolicy {
  id                  String    @id
  org_owner_id        String    @unique(map: "org_ops_policy_org_owner_id")
  assignment_strategy String    @default("least_loaded")
  sla_targets         Json?
  escalation_rules    Json?
  workload_caps       Json?
  round_robin_index   Int       @default(0)
  active              Boolean   @default(true)
  created_at          DateTime  @default(now())
  updated_at          DateTime?

  @@map("org_ops_policies")
}

model LeadSlaTimer {
  id             String    @id
  lead_id        String
  org_owner_id   String
  stage          String
  target_minutes Int
  deadline_at    DateTime
  breached_at    DateTime?
  resolved_at    DateTime?
  created_at     DateTime  @default(now())
  updated_at     DateTime?
  lead           Lead      @relation(fields: [lead_id], references: [id], onDelete: Cascade, map: "lead_sla_timers_lead_fk")

  @@unique([lead_id, stage], name: "lead_sla_timers_lead_id_stage", map: "lead_sla_timers_lead_id_stage")
  @@index([org_owner_id, deadline_at], map: "lead_sla_timers_org_deadline")
  @@map("lead_sla_timers")
}

model LeadEscalation {
  id              String    @id
  lead_id         String
  org_owner_id    String
  sla_timer_id    String?
  severity        String?
  reason          String
  triggered_by    String?
  triggered_at    DateTime  @default(now())
  resolved_at     DateTime?
  resolved_by     String?
  resolution_note String?
  created_at      DateTime  @default(now())
  updated_at      DateTime?
  lead            Lead      @relation(fields: [lead_id], references: [id], onDelete: Cascade, map: "lead_escalations_lead_fk")

  @@index([lead_id, resolved_at], map: "lead_escalations_lead_resolved")
  @@index([org_owner_id, triggered_at], map: "lead_escalations_org_triggered")
  @@map("lead_escalations")
}

model AgentWorkload {
  id               String    @id
  org_owner_id     String
  agent_id         String
  active_leads     Int       @default(0)
  capped_max_leads Int       @default(10)
  last_assigned_at DateTime?
  updated_at       DateTime  @default(now())

  @@unique([org_owner_id, agent_id], name: "agent_workloads_org_owner_id_agent_id", map: "agent_workloads_org_owner_id_agent_id")
  @@index([org_owner_id, active_leads], map: "agent_workloads_org_active_leads")
  @@map("agent_workloads")
}

model LeadNote {
  id                                   String   @id
  lead_id                              String
  org_owner_id                         String
  author_id                            String
  note                                 String?
  created_at                           DateTime @default(now())
  author                               User     @relation("LeadNoteAuthor", fields: [author_id], references: [id])
  lead                                 Lead     @relation(fields: [lead_id], references: [id], onDelete: Cascade)
  users_lead_notes_org_owner_idTousers User     @relation("lead_notes_org_owner_idTousers", fields: [org_owner_id], references: [id])

  @@index([lead_id, created_at])
  @@map("lead_notes")
}

model LeadReminder {
  id                                       String    @id
  lead_id                                  String
  org_owner_id                             String
  created_by                               String
  remind_at                                DateTime
  message                                  String?
  done                                     Boolean   @default(false)
  created_at                               DateTime  @default(now())
  notified_at                              DateTime?
  creator                                  User      @relation("LeadReminderCreator", fields: [created_by], references: [id])
  lead                                     Lead      @relation(fields: [lead_id], references: [id], onDelete: Cascade)
  users_lead_reminders_org_owner_idTousers User      @relation("lead_reminders_org_owner_idTousers", fields: [org_owner_id], references: [id])

  @@index([lead_id, remind_at, done])
  @@map("lead_reminders")
}

model InteractionLog {
  id               String       @id
  org_owner_id     String
  actor_id         String?
  channel          String?
  interaction_type String
  entity_type      String?
  entity_id        String?
  match_id         String?
  metadata         Json?
  occurred_at      DateTime
  created_at       DateTime     @default(now())
  lead_id          String?
  message_id       String?
  call_session_id  String?
  event_log_id     String?
  actor            User?        @relation("InteractionActor", fields: [actor_id], references: [id])
  callSession      CallSession? @relation(fields: [call_session_id], references: [id])
  eventLog         EventLog?    @relation(fields: [event_log_id], references: [id])
  lead             Lead?        @relation(fields: [lead_id], references: [id])
  message          Message?     @relation(fields: [message_id], references: [id])
  orgOwner         User         @relation("InteractionOrgOwner", fields: [org_owner_id], references: [id])

  @@index([org_owner_id, interaction_type, occurred_at])
  @@map("interaction_logs")
}

model EventLog {
  id                                   String           @id
  org_owner_id                         String
  actor_id                             String?
  event_type                           String
  entity_type                          String?
  entity_id                            String?
  payload                              Json?
  occurred_at                          DateTime
  created_at                           DateTime         @default(now())
  users_event_logs_actor_idTousers     User?            @relation("event_logs_actor_idTousers", fields: [actor_id], references: [id])
  users_event_logs_org_owner_idTousers User             @relation("event_logs_org_owner_idTousers", fields: [org_owner_id], references: [id])
  interactions                         InteractionLog[]

  @@index([org_owner_id, event_type, occurred_at])
  @@map("event_logs")
}

model AnalyticsEvent {
  id         String   @id
  type       String
  actor_id   String?
  entity_id  String?
  metadata   Json?
  created_at DateTime @default(now())

  @@map("analytics")
}

model Boost {
  id           String    @id
  user_id      String
  scope        String
  multiplier   Float
  status       String
  starts_at    DateTime
  ends_at      DateTime
  price_usd    Float
  created_at   DateTime  @default(now())
  cancelled_at DateTime?

  @@map("boosts")
}

model ProductView {
  id         String    @id
  user_id    String
  product_id String
  viewed_at  DateTime  @default(now())
  created_at DateTime  @default(now())
  updated_at DateTime?

  @@map("product_views")
}

model Report {
  id                String    @id
  status            String
  entity_type       String
  entity_id         String
  reason            String?
  actor_id          String?
  actor_name        String?
  created_at        DateTime  @default(now())
  resolved_at       DateTime?
  resolved_by       String?
  resolution_action String?
  resolution_note   String?

  @@map("reports")
}

model PolicyViolation {
  id                         String    @id
  actor_id                   String
  kind                       String?
  reason                     String?
  entity_type                String?
  entity_id                  String?
  snippet                    String?
  strikes                    Int?
  action                     String?
  restrict_hours             Int?
  messaging_restricted_until DateTime?
  meta                       Json?
  created_at                 DateTime  @default(now())

  @@map("violations")
}

model SocialInteraction {
  id               String   @id
  interaction_type String
  entity_type      String
  entity_id        String
  actor_id         String
  actor_name       String?
  actor_verified   Boolean?
  text             String?
  created_at       DateTime @default(now())

  @@map("social_interactions")
}

model UserConnection {
  id           String    @id
  type         String
  requester_id String
  receiver_id  String
  status       String
  created_at   DateTime  @default(now())
  updated_at   DateTime?

  @@map("user_connections")
}

model Match {
  requirement_id String
  factory_id     String
  score          Int?
  status         String?
  created_at     DateTime @default(now())

  @@id([requirement_id, factory_id], name: "requirement_id_factory_id")
  @@map("matches")
}

model WorkflowJourney {
  id             String               @id
  match_id       String?
  requirement_id String?
  product_id     String?
  contract_id    String?
  current_state  String
