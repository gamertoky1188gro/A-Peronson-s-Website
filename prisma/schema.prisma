  sla_targets         Json?
  escalation_windows  Json?
  active              Boolean   @default(true)
  created_at          DateTime  @default(now())
  updated_at          DateTime?

  @@unique([org_id, code], name: "org_id_policy_code", map: "org_id_policy_code")
  @@map("org_policies")
}

model PolicyDefinition {
  id          String          @id
  code        String          @unique
  name        String
  description String?
  active      Boolean         @default(true)
  created_by  String?
  created_at  DateTime        @default(now())
  updated_at  DateTime?
  versions    PolicyVersion[]

  @@map("policy_definitions")
}

model PolicyVersion {
  id                   String            @id
  policy_definition_id String
  version              Int
  status               String            @default("draft")
  effective_from       DateTime
  effective_to         DateTime?
  rules                Json?
  created_by           String?
  created_at           DateTime          @default(now())
  updated_at           DateTime?
  scopes               PolicyRuleScope[]
  policy               PolicyDefinition  @relation(fields: [policy_definition_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([policy_definition_id, version], name: "policy_definition_version", map: "policy_definition_version")
  @@index([effective_from, effective_to], map: "policy_versions_effective_dates_idx")
  @@map("policy_versions")
}

model PolicyRuleScope {
  id                String        @id
  policy_version_id String
  scope_type        String
  scope_value       String
  created_at        DateTime      @default(now())
  policy_version    PolicyVersion @relation(fields: [policy_version_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([scope_type, scope_value], map: "policy_rule_scopes_scope_idx")
  @@map("policy_rule_scopes")
}

